{
  "name": "ai-fundamentals",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run generate:assets && vite",
    "generate:assets": "node scripts/generate-takumi-assets.mjs",
