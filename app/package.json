    "react-rewards": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "takumi-js": "^1.8.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
