# Downloaded papers and research corpora are reproducible from the indexes.
papers/**/*.pdf
data/**/*.parquet
data/**/*.jsonl
data/**/*.jsonl.gz
data/**/*.arrow
data/**/*.sqlite
data/**/*.db

# Raw GitHub HTML snapshots can contain public-page CSRF fields.
resources/raw/github-*.html

# Avoid committing cloned upstream repositories into this study repo.
repos/*
!repos/README.md

